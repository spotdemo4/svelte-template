{
	"semantic_tokens": "combined",
	"file_types": {
		"Shell Script": [".envrc*"],
	},
	"lsp": {
		"tailwindcss-language-server": {
			"settings": {
				"includeLanguages": {
					"svelte": "html",
				},
				"experimental": {
					"classRegex": [
						"class=\"([^\"]*)\"",
						"class='([^']*)'",
						"class:\\s*([^\\s{]+)",
						"\\{\\s*class:\\s*\"([^\"]*)\"",
						"\\{\\s*class:\\s*'([^']*)'",
					],
				},
			},
		},
		"nixd": {
			"settings": {
				"nixpkgs": {
					"expr": "(builtins.getFlake (builtins.toString ./.)).outputs.nixpkgs.${builtins.currentSystem}",
				},
			},
		},
	},
	"languages": {
		"TypeScript": {
			"format_on_save": "on",
			"language_servers": ["tsgo", "vtsls", "eslint", "tailwindcss-language-server"],
			"code_actions_on_format": {
				"source.fixAll.eslint": true,
			},
		},
		"CSS": {
			"format_on_save": "on",
			"language_servers": ["!vscode-css-language-server", "tailwindcss-intellisense-css", "..."],
		},
		"HTML": {
			"format_on_save": "on",
		},
	},
}
